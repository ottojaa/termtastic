<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- QR pairing scanner; the zxing CaptureActivity requests it at runtime. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Normal permission (no prompt): lets connection-failure messages say
         whether the phone is on Wi-Fi or mobile data. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera is only needed for pairing; the app works without one. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:label="Termtastic"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Termtastic">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Pairing deep link: scanning the QR with the system camera (or
                 any browser hitting termtastic://pair) opens the app straight
                 into the pairing flow. singleTask + onNewIntent above keep an
                 already-running app in place instead of relaunching it. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="termtastic" android:host="pair" />
            </intent-filter>
        </activity>
    </application>
</manifest>
